LLM_PROVIDER=mistral
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY_HERE
MISTRAL_BASE_URL=https://api.mistral.ai/v1
LLM_MODEL=mistral-small-latest
# Optional local provider (OpenAI-compatible Ollama endpoint):
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=llama3.2
# OLLAMA_API_KEY=ollama

# Shared LLM throttling controls (live mode)
MAX_CONCURRENT_LLM=1
LLM_REQUEST_DELAY=1.25
LLM_BACKOFF_BASE_SEC=1.2
LLM_BACKOFF_JITTER_SEC=0.5
LLM_BACKOFF_MAX_SEC=20

# Fast mode is default to keep full runs near one minute for 180 contacts.
# Set to 0 only when you intentionally want live web + LLM calls.
FAST_MODE=1
FAST_MODE_USE_LINKEDIN_CACHE=1

# Event date used for PRE_EVENT / DURING_EVENT / POST_EVENT routing windows.
EVENT_DATE=2025-11-07

# LinkedIn lookup backend controls (live mode only)
LINKEDIN_SEARCH_BACKEND=brave
ENABLE_DDG_LINKEDIN_FALLBACK=0
LINKEDIN_LOOKUP_DELAY_SEC=0.35
BRAVE_MAX_RETRIES=4
BRAVE_RETRY_BACKOFF_SEC=1.2
BING_MAX_RETRIES=3
BING_RETRY_BACKOFF_SEC=0.8
ENRICH_MAX_WORKERS=2

# News signal controls (live mode only)
ENABLE_DDG_NEWS_FALLBACK=0

# Optional expensive enrichers (live mode only)
DISABLE_INDUSTRY_LLM=1
ENABLE_PREVIOUS_ROLE_LLM=0
PREVIOUS_ROLE_LLM_RETRIES=2
MIN_PERSONA_CONFIDENCE=1
PERSONA_MAX_WORKERS=1
PERSONA_RETRY_ATTEMPTS=1
PERSONA_FAIL_FAST_ON_429=1
PERSONA_DISABLE_LLM_ON_RATE_LIMIT=1
PERSONA_RATE_LIMIT_SWITCH_THRESHOLD=3
OUTREACH_MAX_WORKERS=1
OUTREACH_RETRY_ATTEMPTS=1
OUTREACH_FAIL_FAST_ON_429=1
OUTREACH_DISABLE_LLM_ON_RATE_LIMIT=1
OUTREACH_RATE_LIMIT_SWITCH_THRESHOLD=3
PERSONA_ROW_DELAY_SEC=0
OUTREACH_ROW_DELAY_SEC=0
MIN_ROUTE_CONFIDENCE=2
MIN_ROUTE_EVIDENCE_SCORE=35

# Optional dispatch bridge for approved outreach drafts.
# DISPATCH_MODE=file
# DISPATCH_WEBHOOK_URL=https://hook.example.com/your-endpoint
# DISPATCH_MAX_RETRIES=3
# DISPATCH_TIMEOUT_SEC=10

# Safety against accidental partial runs on assignment-size datasets
DDG_BATCH_CAP=180
ALLOW_PARTIAL_LIVE_ENRICH=0
PIPELINE_FAIL_FAST=1
PIPELINE_STAGE_INPUT_GUARD=1
PIPELINE_INPUT_MAX_AGE_MINUTES=180

# Fuzzy dedup guardrail for very large company/name blocks
FUZZY_BLOCK_MAX=180

# Web app security defaults
WEB_APP_HOST=127.0.0.1
# WEB_APP_TOKEN=set-a-secret-token-for-run-stop-approval
